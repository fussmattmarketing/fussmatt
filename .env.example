# =============================================================================
# FussMatt v2 — Environment Variables
# Copy to .env.local for development. Production values go in Vercel Dashboard.
# =============================================================================

# WooCommerce API (wp.fussmatt.com)
WORDPRESS_URL=               # https://wp.fussmatt.com
NEXT_PUBLIC_WORDPRESS_URL=   # https://wp.fussmatt.com
WC_CONSUMER_KEY=             # ck_XXXXX
WC_CONSUMER_SECRET=          # cs_XXXXX
WP_APPLICATION_USER=         # WordPress application username
WP_APPLICATION_PASSWORD=     # WordPress application password

# Stripe
STRIPE_SECRET_KEY=           # sk_live_XXXXX or sk_test_XXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # pk_live_XXXXX or pk_test_XXXXX
STRIPE_WEBHOOK_SECRET=       # whsec_XXXXX

# Site
NEXT_PUBLIC_SITE_URL=        # https://fussmatt.com
NEXT_PUBLIC_SITE_NAME=       # FussMatt

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=          # GTM-XXXXX

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=      # https://XXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=    # XXXXX

# Sentry (Error Tracking)
SENTRY_DSN=                  # https://XXXXX@sentry.io/XXXXX
SENTRY_AUTH_TOKEN=           # sntrys_XXXXX

# B2B Sync
B2B_FEED_URL=                # Full URL to B2B XML feed (hardcoded YASAK)
SYNC_SECRET_KEY=             # Random 64-char key for sync API auth (fallback YASAK)

# Resend (Back-in-Stock Email Notifications)
RESEND_API_KEY=              # re_XXXXX — from resend.com
RESEND_FROM_EMAIL=           # noreply@fussmatt.com — verified sender domain
